{
    "name": "sirix/container-resolver",
    "description": "Strict PSR-11 container service resolver and typed configuration reader",
    "license": "MIT",
    "keywords": [
        "psr-11",
        "container",
        "configuration",
        "config",
        "factory",
        "strict"
    ],
    "authors": [
        {
            "name": "Sirix",
            "homepage": "https://github.com/sirix777"
        }
    ],
    "require": {
        "php": "~8.2.0 || ~8.3.0 || ~8.4.0 || ~8.5.0",
        "psr/container": "^1.0 || ^2.0"
    },
    "require-dev": {
        "bamarni/composer-bin-plugin": "^1.8",
        "phpunit/phpunit": "^11.5"
    },
    "autoload": {
        "psr-4": {
            "Sirix\\ContainerResolver\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SirixTest\\ContainerResolver\\": "test/"
        }
    },
    "config": {
        "allow-plugins": {
            "bamarni/composer-bin-plugin": true
        },
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "extra": {
        "bamarni-bin": {
            "bin-links": false,
            "forward-command": true,
            "target-directory": "tools"
        }
    },
    "scripts": {
        "analyse-deps": "tools/composer-dependency-analyser/vendor/bin/composer-dependency-analyser --config composer-dependency-analyser.php",
        "check": [
            "@analyse-deps",
            "@cs-check",
            "@rector",
            "@phpstan",
            "@test"
        ],
        "cs-check": "php tools/php-cs-fixer/vendor/bin/php-cs-fixer fix --dry-run -vvv --diff",
        "cs-fix": "php tools/php-cs-fixer/vendor/bin/php-cs-fixer fix -vvv",
        "normalize": "@composer bin composer-normalize normalize --diff ../../composer.json",
        "phpstan": "php tools/phpstan/vendor/bin/phpstan analyse -c phpstan.neon --memory-limit=2G",
        "rector": "php tools/rector/vendor/bin/rector process --dry-run --memory-limit=2G",
        "rector-fix": "php tools/rector/vendor/bin/rector process --memory-limit=2G",
        "test": "php vendor/bin/phpunit --colors=always --testdox"
    }
}
